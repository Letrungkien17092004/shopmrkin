{
  "name": "server",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "npx tsx watch ./src/app.ts",
    "start": "node ./dist/app.js",
    "postinstall": "prisma generate --schema=./src/services/postgresSQL/prisma/schema.prisma",
    "build": "npx tsc",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "test:cart": "cross-env NODE_OPTIONS=--experimental-vm-modules jest Cart",
    "test:verbose": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --verbose",
    "test:clear": "jest --clearCache",
    "prisma-generate": "npx prisma generate --schema=./src/services/postgresSQL/prisma/schema.prisma",
    "prisma-migrate": "npx prisma migrate --skip-seed dev --schema=./src/services/postgresSQL/prisma/schema.prisma",
    "prisma-migrate-co": "npx prisma migrate dev --create-only --schema=./src/services/postgresSQL/prisma/schema.prisma",
    "prisma-studio": "npx prisma studio --schema=./src/services/postgresSQL/prisma/schema.prisma",
    "prisma-reset": "npx prisma migrate reset --skip-seed --schema=./src/services/postgresSQL/prisma/schema.prisma",
    "prisma-seed": "npx tsx ./src/services/postgresSQL/prisma/seed.ts",
    "show-config": "npx tsx ./src/config/env.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "dependencies": {
    "@google/genai": "^1.33.0",
    "@prisma/client": "^6.11.1",
    "@types/axios": "^0.9.36",
    "@types/bcrypt": "^6.0.0",
    "@types/body-parser": "^1.19.6",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.1.0",
    "axios": "^1.12.2",
    "bcrypt": "^6.0.0",
    "body-parser": "^2.2.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "openai": "^6.13.0",
    "prisma": "^6.11.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "zod": "^4.0.17",
    "zod-to-json-schema": "^3.25.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/jest": "^29.5.12",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5"
  }
}
